# Core runtime
PYTHONUNBUFFERED=1
YOLO_DEVICE=cpu
PIPELINE_WORK_ROOT=/app/runtime
PIPELINE_TMP_ROOT=/tmp/ballot-runtime

# Model artifacts (must point to existing files; do not retrain)
STAMP_WEIGHTS=/var/task/stamp-detection/runs/train/yolo_stamp/weights/best.pt
DIGIT_MODEL=/var/task/Handwritten-Digit-Recognition/tf-cnn-model.keras

# Supabase
SUPABASE_URL=https://wcuzjrawfvhocbaibfbi.supabase.co
SUPABASE_KEY=
ELECTION_ID=1
SUPABASE_HTTP_TIMEOUT_SEC=30

# Box location fallback when current_box.json is unavailable (Lambda)
BOX_LOCATION=mayo

# AWS (for local testing; in AWS use IAM role instead)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3/Lambda event processing
S3_INPUT_BUCKET=
IDEMPOTENCY_TABLE=ballot-processing-idempotency
IDEMPOTENCY_TTL_DAYS=7

# Optional local/dev upload path routing
S3_INPUT_PREFIX=raw-images/
